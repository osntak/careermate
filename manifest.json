{
  "manifest_version": "0.3",
  "name": "careermate",
  "display_name": "CareerMate",
  "version": "0.0.2",
  "description": "내 AI를 커리어 비서로 — 이력서·자기소개서·지원 현황을 이 컴퓨터에만 저장하고 MCP로 연결하는 로컬 커리어 관리 도구.",
  "long_description": "CareerMate는 LLM을 포함하지 않습니다. 사용자의 Claude가 MCP 도구로 로컬 커리어 데이터(프로필·이력서·자기소개서·공고·지원 현황)를 읽고 씁니다. 모든 데이터는 ~/.careermate 에만 저장되며 외부로 전송되지 않습니다. 자기소개서 작성 시에는 'AI 티 안 나는 글쓰기' 규칙을 함께 적용합니다.",
  "author": {
    "name": "CareerMate"
  },
  "homepage": "https://github.com/osntak/careermate",
  "documentation": "https://github.com/osntak/careermate/blob/main/docs/MCP_TOOLS.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/osntak/careermate"
  },
  "license": "MIT",
  "keywords": [
    "career",
    "resume",
    "cover-letter",
    "korean",
    "mcp",
    "local-first"
  ],
  "server": {
    "type": "node",
    "entry_point": "dist/mcp.mjs",
    "mcp_config": {
      "command": "node",
      "args": [
        "--experimental-sqlite",
        "${__dirname}/dist/mcp.mjs"
      ]
    }
  },
  "tools": [
    {
      "name": "get_onboarding_status",
      "description": "온보딩 상태 확인"
    },
    {
      "name": "start_onboarding",
      "description": "온보딩 시작 안내"
    },
    {
      "name": "get_profile",
      "description": "프로필 조회"
    },
    {
      "name": "save_profile",
      "description": "프로필 저장"
    },
    {
      "name": "update_profile",
      "description": "프로필 부분 수정"
    },
    {
      "name": "add_resume",
      "description": "이력서/경력기술서 추가"
    },
    {
      "name": "get_resumes",
      "description": "이력서 목록 조회"
    },
    {
      "name": "add_cover_letter",
      "description": "자기소개서 추가"
    },
    {
      "name": "get_cover_letters",
      "description": "자기소개서 목록 조회"
    },
    {
      "name": "save_cover_letter_version",
      "description": "자기소개서 버전 저장"
    },
    {
      "name": "save_job_posting",
      "description": "채용공고 저장"
    },
    {
      "name": "get_job_posting",
      "description": "채용공고 상세 조회"
    },
    {
      "name": "list_jobs",
      "description": "저장된 공고 목록"
    },
    {
      "name": "parse_job_posting",
      "description": "공고 텍스트 정리"
    },
    {
      "name": "get_application_context",
      "description": "지원 맥락 한 번에 가져오기 ⭐"
    },
    {
      "name": "save_fit_analysis",
      "description": "적합도 분석 결과 저장"
    },
    {
      "name": "update_application_status",
      "description": "지원 상태 변경"
    },
    {
      "name": "save_interview_prep",
      "description": "면접 준비 자료 저장"
    },
    {
      "name": "export_cover_letter",
      "description": "자기소개서 내보내기"
    },
    {
      "name": "open_dashboard",
      "description": "대시보드 열기"
    },
    {
      "name": "open_application",
      "description": "지원/공고 페이지 열기"
    },
    {
      "name": "list_recent_activity",
      "description": "최근 활동 조회"
    },
    {
      "name": "get_workflow_guide",
      "description": "워크플로우 가이드"
    },
    {
      "name": "get_writing_style_guide",
      "description": "AI 티 안 나는 글쓰기 가이드"
    }
  ],
  "compatibility": {
    "platforms": [
      "win32",
      "darwin",
      "linux"
    ],
    "runtimes": {
      "node": ">=22.5.0"
    }
  }
}
