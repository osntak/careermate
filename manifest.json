{
  "manifest_version": "0.3",
  "name": "careermate",
  "display_name": "CareerMate",
  "version": "0.0.8",
  "description": "내 AI를 커리어 비서로 — 이력서·자기소개서·지원 현황을 이 컴퓨터에만 저장하고 MCP로 연결하는 로컬 커리어 관리 도구.",
  "long_description": "CareerMate는 LLM을 포함하지 않습니다. 사용자의 Claude가 MCP 도구로 로컬 커리어 데이터(프로필·이력서·자기소개서·공고·지원 현황)를 읽고 씁니다. 모든 데이터는 ~/.careermate 에만 저장되며 외부로 전송되지 않습니다. 자기소개서 작성 시에는 'AI 티 안 나는 글쓰기' 규칙을 함께 적용합니다.",
  "author": {
    "name": "CareerMate"
  },
  "homepage": "https://github.com/osntak/careermate",
  "documentation": "https://github.com/osntak/careermate/blob/main/docs/MCP_TOOLS.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/osntak/careermate"
  },
  "license": "MIT",
  "keywords": [
    "career",
    "resume",
    "cover-letter",
    "korean",
    "mcp",
    "local-first"
  ],
  "server": {
    "type": "node",
    "entry_point": "dist/mcp.mjs",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/dist/mcp.mjs"
      ]
    }
  },
  "tools": [
    {
      "name": "read_document",
      "description": "문서 파일 읽기 (PDF·Word·HWP)"
    },
    {
      "name": "open_inbox",
      "description": "문서 인입 폴더 열기"
    },
    {
      "name": "read_inbox",
      "description": "인입 폴더 파일 읽기"
    },
    {
      "name": "get_onboarding_status",
      "description": "온보딩 상태 확인"
    },
    {
      "name": "get_profile",
      "description": "프로필 조회"
    },
    {
      "name": "save_profile",
      "description": "프로필 저장"
    },
    {
      "name": "add_resume",
      "description": "이력서/경력기술서 추가"
    },
    {
      "name": "get_resumes",
      "description": "이력서 목록 조회"
    },
    {
      "name": "delete_resume",
      "description": "이력서/문서 삭제"
    },
    {
      "name": "add_experience",
      "description": "경력 추가"
    },
    {
      "name": "get_experiences",
      "description": "경력 목록 조회"
    },
    {
      "name": "delete_experience",
      "description": "경력 항목 삭제"
    },
    {
      "name": "add_project",
      "description": "프로젝트 추가"
    },
    {
      "name": "get_projects",
      "description": "프로젝트 목록 조회"
    },
    {
      "name": "delete_project",
      "description": "프로젝트 항목 삭제"
    },
    {
      "name": "add_skill",
      "description": "기술스택 추가"
    },
    {
      "name": "get_skills",
      "description": "기술스택 목록 조회"
    },
    {
      "name": "delete_skill",
      "description": "기술스택 항목 삭제"
    },
    {
      "name": "get_cover_letters",
      "description": "자기소개서 목록 조회"
    },
    {
      "name": "save_cover_letter_version",
      "description": "자기소개서 버전 저장"
    },
    {
      "name": "delete_cover_letter",
      "description": "자기소개서 삭제"
    },
    {
      "name": "save_job_posting",
      "description": "채용공고 저장"
    },
    {
      "name": "get_job_posting",
      "description": "채용공고 상세 조회"
    },
    {
      "name": "list_jobs",
      "description": "저장된 공고 목록"
    },
    {
      "name": "prescreen_job",
      "description": "공고 사전 프리스크린(키워드 겹침)"
    },
    {
      "name": "search_jobs",
      "description": "공고 검색·가져오기(키워드, 무인증 공개 잡보드)"
    },
    {
      "name": "save_offer",
      "description": "오퍼(제안) 저장 — 총보상·AI 점수·최종평"
    },
    {
      "name": "compare_offers",
      "description": "오퍼 비교(점수순·현금성 총액 추정)"
    },
    {
      "name": "get_offer",
      "description": "오퍼 조회(공고별)"
    },
    {
      "name": "delete_job_posting",
      "description": "채용공고 삭제"
    },
    {
      "name": "get_application_context",
      "description": "지원 맥락 한 번에 가져오기 ⭐"
    },
    {
      "name": "save_fit_analysis",
      "description": "적합도 분석 결과 저장"
    },
    {
      "name": "update_application_status",
      "description": "지원 상태 변경"
    },
    {
      "name": "save_interview_prep",
      "description": "면접 준비 자료 저장"
    },
    {
      "name": "export_cover_letter",
      "description": "자기소개서 내보내기"
    },
    {
      "name": "export_resume",
      "description": "이력서/문서 내보내기"
    },
    {
      "name": "export_profile",
      "description": "프로필을 이력서로 내보내기"
    },
    {
      "name": "open_dashboard",
      "description": "대시보드 열기"
    },
    {
      "name": "open_application",
      "description": "지원/공고 페이지 열기"
    },
    {
      "name": "list_recent_activity",
      "description": "최근 활동 조회"
    },
    {
      "name": "get_followups",
      "description": "후속 조치 알림(무응답 지원·마감·면접준비)"
    },
    {
      "name": "get_pipeline_stats",
      "description": "지원 파이프라인 분석(깔때기·합격률)"
    },
    {
      "name": "get_workflow_guide",
      "description": "워크플로우 가이드"
    },
    {
      "name": "get_playbook",
      "description": "전문가 플레이북"
    },
    {
      "name": "get_verifier",
      "description": "검증 루브릭 (저장 전 자가검증)"
    },
    {
      "name": "validate_cover_letter",
      "description": "자기소개서 자동 점검 (저장 전 미리보기)"
    },
    {
      "name": "set_verify_mode",
      "description": "점검 모드 설정 (기본/엄격)"
    },
    {
      "name": "get_writing_style_guide",
      "description": "AI 티 안 나는 글쓰기 가이드"
    },
    {
      "name": "check_for_update",
      "description": "업데이트 확인"
    },
    {
      "name": "update_careermate",
      "description": "CareerMate 업데이트"
    }
  ],
  "compatibility": {
    "platforms": [
      "win32",
      "darwin",
      "linux"
    ],
    "runtimes": {
      "node": ">=22.13.0"
    }
  }
}
